{
  "AllowedHosts": "*",
  "Database": {
    "ApplyMigrationsOnStartup": false,
    "CommandTimeoutSeconds": 30,
    "MaxPoolSize": 15
  },
  "Swagger": {
    "Enabled": true
  },
  "Jwt": {
    "Issuer": "mirage-api",
    "Audience": "mirage-client",
    "SigningKey": "replace-with-a-secret-of-at-least-32-bytes",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 30
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  }
}
