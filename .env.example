# PostgreSQL URI. Never commit the real credential.
DATABASE_URL=postgres://user:password@host:5432/database?sslmode=require

# Use a random secret of at least 32 bytes in every deployed environment.
Jwt__SigningKey=replace-with-a-long-random-production-secret
Jwt__Issuer=mirage-api
Jwt__Audience=mirage-client
Jwt__AccessTokenMinutes=15
Jwt__RefreshTokenDays=30

# Development convenience only. Render runs migrations through its pre-deploy command.
Database__ApplyMigrationsOnStartup=true
Database__MaxPoolSize=15
Database__CommandTimeoutSeconds=30

Swagger__Enabled=true

Cors__AllowedOrigins__0=http://localhost:5173
Cors__AllowedOrigins__1=https://your-vercel-project.vercel.app
